{
  "uid": "advisoryhub-overview",
  "title": "AdvisoryHub — Overview",
  "tags": ["advisoryhub"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (by method)",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (rate(django_http_requests_total_by_method_total[5m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx error ratio (5m)",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(django_http_responses_total_by_status_total[5m])), 1e-9)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Targets up",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=~\"advisoryhub-.*\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request latency (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(django_http_requests_latency_seconds_by_view_method_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Responses by status",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(django_http_responses_total_by_status_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    }
  ]
}
