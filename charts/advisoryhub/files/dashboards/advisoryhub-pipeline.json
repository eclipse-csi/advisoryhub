{
  "uid": "advisoryhub-pipeline",
  "title": "AdvisoryHub — Pipeline & Backlog",
  "tags": ["advisoryhub"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Publication outcomes",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(advisoryhub_publication_total[15m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Publication duration (p95)",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(advisoryhub_publication_duration_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Celery task throughput (by status)",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(advisoryhub_celery_task_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Operator backlog (by queue)",
      "datasource": { "type": "prometheus", "uid": "advisoryhub-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "advisoryhub_backlog",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
